{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Manrope|Quicksand))/i]",
        "message": "Font not provided by the design system. Available: Manrope, Quicksand."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|dotColor|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, dotColor, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|mint|outline|dark|status)$/]",
        "message": "<Badge> variant must be one of 'solid' | 'mint' | 'outline' | 'dark' | 'status'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|dark|secondary|tertiary|text)$/]",
        "message": "<Button> variant must be one of 'primary' | 'dark' | 'secondary' | 'tertiary' | 'text'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Button> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FinancialColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|type|key|ref|className|style|children)$/]",
        "message": "<FinancialColumn> doesn't accept that prop. Declared props: label, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='FinancialColumn'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:actual|proj)$/]",
        "message": "<FinancialColumn> type must be one of 'actual' | 'proj'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|accent|tile|size|strokeWidth|color|key|ref|className|style|children)$/]",
        "message": "<IconTile> doesn't accept that prop. Declared props: children, accent, tile, size, strokeWidth, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='KPICard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|sublabel|trend|trendDir|variant|key|ref|className|style|children)$/]",
        "message": "<KPICard> doesn't accept that prop. Declared props: label, value, sublabel, trend, trendDir, variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='KPICard'] > JSXAttribute[name.name='trendDir'] > Literal[value!=/^(?:up|down|none)$/]",
        "message": "<KPICard> trendDir must be one of 'up' | 'down' | 'none'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KPICard'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:light|mint|green|dark)$/]",
        "message": "<KPICard> variant must be one of 'light' | 'mint' | 'green' | 'dark'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Badge": {
        "replaces": []
      },
      "Button": {
        "replaces": []
      },
      "FinancialColumn": {
